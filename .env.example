# ─── Shopify Storefront API (public, used by Next.js frontend) ────────────────
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-public-token

# ─── Shopify Admin API (private, server-side DAO layer only) ──────────────────
# Generate in: Shopify Admin > Settings > Apps > Develop apps
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
SHOPIFY_API_VERSION=2025-07

# ─── External Storefront Domain (for password reset emails) ────────────────────
# Used in password reset flow to redirect users to your custom domain
# Example: https://www.yourdomain.com (for production)
# Example: http://localhost:3000 (for local development)
NEXT_PUBLIC_STOREFRONT_DOMAIN=https://www.yourdomain.com

# ─── Shopify Customer Account API (new accounts OAuth) ───────────────────────
# Client ID shown in Customer Account API configuration.
# For compatibility, SHOPIFY_CLIENT_ID and SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID can be the same.
NEXT_PUBLIC_SHOPIFY_CLIENT_ID=your-customer-account-client-id
SHOPIFY_CLIENT_ID=your-customer-account-client-id
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=your-customer-account-client-id

# Full OAuth endpoints from Shopify Customer Account API config page.
NEXT_PUBLIC_SHOPIFY_CUSTOMER_ACCOUNT_AUTHORIZE_ENDPOINT=https://shopify.com/authentication/<shop-id>/oauth/authorize
SHOPIFY_CUSTOMER_ACCOUNT_TOKEN_ENDPOINT=https://shopify.com/authentication/<shop-id>/oauth/token
SHOPIFY_CUSTOMER_ACCOUNT_REDIRECT_URI=https://www.yourdomain.com/auth/callback
NEXT_PUBLIC_SHOPIFY_CUSTOMER_ACCOUNT_REDIRECT_URI=https://www.yourdomain.com/auth/callback

# ─── Shopify Webhooks ─────────────────────────────────────────────────────────
# Found in: Partner Dashboard > App > Webhooks > Client secret
SHOPIFY_WEBHOOK_SECRET=your-webhook-client-secret

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: debug | info | warn | error
LOG_LEVEL=info
